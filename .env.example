# ── LLM provider ───────────────────────────────────────
# Auto-detected: uses Anthropic if ANTHROPIC_API_KEY is set, otherwise Ollama.
# LLM_PROVIDER=ollama

# ── Ollama (default) ──────────────────────────────────
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_BASE_URL=http://localhost:11434

# ── Anthropic ─────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Embeddings ────────────────────────────────────────
# EMBEDDING_MODEL=nomic-embed-text
# DEDUPE_THRESHOLD=0.85

# ── Fetch limits ──────────────────────────────────────
# MAX_ARTICLE_AGE_DAYS=7
# MAX_ARTICLES_PER_FEED=20

# ── Storage ───────────────────────────────────────────
# Where the SQLite database lives.
# RSS_DATA_DIR=~/.rss-reader

# Where digest markdown files are written.
# Used by `npm run digest`. Overridden by daily.sh when BLOG_DIR is set.
# RSS_DIGESTS_DIR=~/.rss-reader/digests

# ── Blog publishing (used by `npm run daily` only) ───
# Path to your blog repo. If set, daily.sh writes digests to
# $BLOG_DIR/src/content/daily-feed/ and git commits + pushes.
# If not set, daily.sh writes to RSS_DIGESTS_DIR and skips publishing.
# BLOG_DIR=~/Dev/my-blog
